      "end": 330.52,
      "text": "Amén, acá tenemos familias,"
    },
    {
      "start": 330.52,
      "end": 332.52,
      "text": "son familias, amén, ahí dice"
    },
    {
      "start": 332.52,
      "end": 334.52,
      "text": "Arlet Flores Pintado y Feliz"
    },
    {
      "start": 334.52,
      "end": 336.52,
      "text": "Abaldivieso, Dios te bendiga,"
    },
    {
      "start": 336.52,
      "end": 338.52,
      "text": "al lím del testimonio tuyo feliz,"
    },
    {
      "start": 338.52,
      "end": 340.52,
      "text": "está hablando con Víper estos días"
    },
    {
      "start": 340.52,
      "end": 342.52,
      "text": "y ya habrá oportunidad"
    },
    {
      "start": 342.52,
      "end": 344.52,
      "text": "de poder contar cómo Dios ha"
    },
    {
      "start": 344.52,
      "end": 346.52,
      "text": "bendecido tu vida."
    },
    {
      "start": 346.52,
      "end": 348.52,
      "text": "Antonio L. Eradillano,"
    },
    {
      "start": 348.52,
      "end": 350.52,
      "text": "tenemos a, qué bueno,"
    },
    {
      "start": 350.52,
      "end": 352.52,
      "text": "Lacey, también,"
    },
    {
      "start": 352.52,
      "end": 354.52,
      "text": "Lacey también está con nosotros,"
    },
    {
      "start": 354.52,
      "end": 356.52,
      "text": "Amén, Jenny Clemente,"
    },
    {
      "start": 356.52,
      "end": 358.52,
      "text": "Anita, bueno, la familia Polanco,"
    },
    {
      "start": 358.52,
      "end": 360.52,
      "text": "Gretel Gloria Tang,"
    },
    {
      "start": 360.52,
      "end": 362.52,
      "text": "que nos bendiga,"
    },
    {
      "start": 362.52,
      "end": 364.52,
      "text": "Jenny Clemente, Ingrid Chávez,"
    },
    {
      "start": 364.52,
      "end": 366.52,
      "text": "Rosemary,"
    },
    {
      "start": 366.52,
      "end": 368.52,
      "text": "Janice Alsabilka,"
    },
    {
      "start": 368.52,
      "end": 370.52,
      "text": "y ya está Fabricio Soto,"
    },
    {
      "start": 370.52,
      "end": 372.52,
      "text": "bendiciones."
    },
    {
      "start": 372.52,
      "end": 374.52,
      "text": "Lidia Chaucas, hoy día cumple de su bebé,"
    },
    {
      "start": 374.52,
      "end": 376.52,
      "text": "bendiciones. Amén, Majalita,"
    },
    {
      "start": 376.52,
      "end": 378.52,
      "text": "sé que estás ahí, sentadita"
    },
    {
      "start": 378.52,
      "end": 380.52,
      "text": "viéndonos, hoy te saludamos por tu"
    },
    {
      "start": 380.52,
      "end": 382.52,
      "text": "nomás y conméname. Beso bebé, beso."
    },
    {
      "start": 382.52,
      "end": 384.52,
      "text": "Nayeli Santos,"
    },
    {
      "start": 384.52,
      "end": 386.52,
      "text": "Thalía Cano, Norma Liraly,"
    },
    {
      "start": 386.52,
      "end": 388.52,
      "text": "Victor Farfan,"
    },
    {
      "start": 388.52,
      "end": 390.52,
      "text": "Danielito y nosotros,"
    },
    {
      "start": 390.52,
      "end": 392.52,
      "text": "Victor Farfan, Dios te bendiga,"
    },
    {
      "start": 392.52,
      "end": 394.52,
      "text": "qué bueno, te acordaste que se"
    },
    {
      "start": 394.52,
      "end": 396.52,
      "text": "congrega de manera virtual."
    },
    {
      "start": 396.52,
      "end": 398.52,
      "text": "Y quiere que me acuerda de él su voz"
    },
    {
      "start": 398.52,
      "end": 400.52,
      "text": "se amamos, se amamos."
    },
    {
      "start": 400.52,
      "end": 402.52,
      "text": "Amén, vamos comenzando entonces,"
    },
    {
      "start": 402.52,
      "end": 404.52,
      "text": "Magali Medina,"
    },
    {
      "start": 404.52,
      "end": 406.52,
      "text": "Magali,"
    },
    {
      "start": 406.52,
      "end": 408.52,
      "text": "Magali Mesa,"
    },
    {
      "start": 408.52,
      "end": 410.52,
      "text": "Thalía Cano,"
    },
    {
      "start": 410.52,
      "end": 412.52,
      "text": "Jan Marco Santa Cruz, también,"
    },
    {
      "start": 412.52,
      "end": 414.52,
      "text": "y bueno, ya se está conectando"
    },
    {
      "start": 414.52,
      "end": 416.52,
      "text": "muchísimos más,"
    },
    {
      "start": 416.52,
      "end": 418.52,
      "text": "así que sigan ingresando"
    },
    {
      "start": 418.52,
      "end": 420.52,
      "text": "para poder"
    },
    {
      "start": 420.52,
      "end": 422.52,
      "text": "estar conectados y"
    },
    {
      "start": 422.52,
      "end": 424.52,
      "text": "aprender la palabra de Dios."
    },
    {
      "start": 424.52,
      "end": 426.52,
      "text": "También, que Dios bendiga, Luz María Campos,"
    },
    {
      "start": 426.52,
      "end": 428.52,
      "text": "Daisy Espinoza,"
    },
    {
      "start": 428.52,
      "end": 430.52,
      "text": "Nícano Rizko, Edith Astoraime"
    },
    {
      "start": 430.52,
      "end": 432.52,
      "text": "y ahí creo que seguimos ya"
    },
    {
      "start": 432.52,
      "end": 434.52,
      "text": "luego leyendo la ley."
    },
    {
      "start": 434.52,
      "end": 436.52,
      "text": "Dolly, Dolly también está con nosotros."
    },
    {
      "start": 436.52,
      "end": 438.52,
      "text": "Amén, soy Lita Velásquez,"
    },
    {
      "start": 438.52,
      "end": 440.52,
      "text": "Dios te bendiga, amén."
    },
    {
      "start": 440.52,
      "end": 442.52,
      "text": "Edith, y bueno, y seguimos"
    },
    {
      "start": 442.52,
      "end": 444.52,
      "text": "y seguiríamos toda la noche, sería una noche de"
    },
    {
      "start": 444.52,
      "end": 446.52,
      "text": "saludos, así que vamos a empezar,"
    },
    {
      "start": 446.52,
      "end": 448.52,
      "text": "así que también saludar a nuestros"
    },
    {
      "start": 448.52,
      "end": 450.52,
      "text": "hermanos en el extranjero, que Dios los bendiga."
    },
    {
      "start": 450.52,
      "end": 452.52,
      "text": "A todos."
    },
    {
      "start": 452.52,
      "end": 454.52,
      "text": "A mí que enviaron saludos, que Dios bendiga muchísimo"
    },
    {
      "start": 454.52,
      "end": 456.52,
      "text": "en sus vidas,"
    },
    {
      "start": 456.52,
      "end": 458.52,
      "text": "bendiga a nuestros hermanos que están"
    },
    {
      "start": 458.52,
      "end": 460.52,
      "text": "en el interior del país también de Cajamarra,"
    },
    {
      "start": 460.52,
      "end": 462.52,
      "text": "en la diferente parte de Perú,"
    },
    {
      "start": 462.52,
      "end": 464.52,
      "text": "especialmente a los otros hermanos"
    },
    {
      "start": 464.52,
      "end": 466.52,
      "text": "también de Huancayo, que son muchos hermanos."
    },
    {
      "start": 466.52,
      "end": 468.52,
      "text": "Así que qué bueno que perdieron"
    },
    {
      "start": 468.52,
      "end": 470.52,
      "text": "Perú ayer porque si no me equivoco,"
    },
    {
      "start": 470.52,
      "end": 472.52,
      "text": "hay que hay varios que en vez de"
    },
    {
      "start": 472.52,
      "end": 474.52,
      "text": "ver que estaban... ¿Y jugó Perú ayer?"
    },
    {
      "start": 474.52,
      "end": 476.52,
      "text": "No, ayer sí, no, antes ayer, ¿no?"
    },
    {
      "start": 476.52,
      "end": 478.52,
      "text": "En vez de estar en oración,"
    },
    {
      "start": 478.52,
      "end": 480.52,
      "text": "y a veces da risa, y a veces"
    },
    {
      "start": 480.52,
      "end": 482.52,
      "text": "molesta. Que piden"
    },
    {
      "start": 482.52,
      "end": 484.52,
      "text": "oración hasta que se mueren, oren"
    },
    {
      "start": 484.52,
      "end": 486.52,
      "text": "por mí porque estoy con la"
    },
    {
      "start": 486.52,
      "end": 488.52,
      "text": "contaminación y tanta cosa."
    },
    {
      "start": 488.52,
      "end": 490.52,
      "text": "Oramos, ayunamos, hacemos vigina"
    },
    {
      "start": 490.52,
      "end": 492.52,
      "text": "y luego gol,"
    },
    {
      "start": 492.52,
      "end": 494.52,
      "text": "gol que te metan gol a ti."
    },
    {
      "start": 494.52,
      "end": 496.52,
      "text": "Tenemos que estar"
    },
    {
      "start": 496.52,
      "end": 498.52,
      "text": "cuando hay culto, oración es culto"
    },
    {
      "start": 498.52,
      "end": 500.52,
      "text": "de oración, primero es Dios,"
    },
    {
      "start": 500.52,
      "end": 502.52,
      "text": "después la pelota, ¿ven?"
    },
    {
      "start": 502.52,
      "end": 504.52,
      "text": "Primero es Dios, después todo lo que tú quieras,"
    },
    {
      "start": 504.52,
      "end": 506.52,
      "text": "pero primero es Dios, nunca"
    },
    {
      "start": 506.52,
      "end": 508.52,
      "text": "cambies su culto por nada."
    },
    {
      "start": 508.52,
      "end": 510.52,
      "text": "Muy bien, vamos a"
    },
    {
      "start": 510.52,
      "end": 512.52,
      "text": "empezar entonces en esta noche"
    },
    {
      "start": 512.52,
      "end": 514.52,
      "text": "y vamos a empezar con una oración."
    },
    {
      "start": 514.52,
      "end": 516.52,
      "text": "Una oración y decimos de la siguiente"
    },
    {
      "start": 516.52,
      "end": 518.52,
      "text": "manera, padre en el"
    },
    {
      "start": 518.52,
      "end": 520.52,
      "text": "nombre de Jesús. Gracias"
    },
    {
      "start": 520.52,
      "end": 522.52,
      "text": "por extendernos tu misericordia,"
    },
    {
      "start": 522.52,
      "end": 524.52,
      "text": "tu bondad,"
    },
    {
      "start": 524.52,
      "end": 526.52,
      "text": "ese amor Señor"
    },
    {
      "start": 526.52,
      "end": 528.52,
      "text": "que llena nuestras vidas."
    },
    {
      "start": 528.52,
      "end": 530.52,
      "text": "El día de hoy tenemos"
    },
    {
      "start": 530.52,
      "end": 532.52,
      "text": "una revelación de tu palabra Señor."
    },
    {
      "start": 532.52,
      "end": 534.52,
      "text": "Tú nos has entregado"
    },
    {
      "start": 534.52,
      "end": 536.52,
      "text": "tu palabra Señor"
    },
    {
      "start": 536.52,
      "end": 538.52,
      "text": "para escudriñarla,"
    },
    {
      "start": 538.52,
      "end": 540.52,
      "text": "para que a través de tu palabra"
    },
    {
      "start": 540.52,
      "end": 542.52,
      "text": "podamos aprender"
    },
    {
      "start": 542.52,
      "end": 544.52,
      "text": "Señor nuestro caminar,"
    },
    {
      "start": 544.52,
      "end": 546.52,
      "text": "el correcto caminar"
    },
    {
      "start": 546.52,
      "end": 548.52,
      "text": "y también podamos nosotros"
    },
    {
      "start": 548.52,
      "end": 550.52,
      "text": "aprender Señor"
    },
    {
      "start": 550.52,
      "end": 552.52,
      "text": "todo lo relacionado"
    },
    {
      "start": 552.52,
      "end": 554.52,
      "text": "bendito Señor a la estructura"
    },
    {
      "start": 554.52,
      "end": 556.52,
      "text": "de los seres"
    },
    {
      "start": 556.52,
      "end": 558.52,
      "text": "celestiales y todo"
    },
    {
      "start": 558.52,
      "end": 560.52,
      "text": "cuanto tu Señor Dios"
    },
    {
      "start": 560.52,
      "end": 562.52,
      "text": "has permitido que el hombre"
    },
    {
      "start": 562.52,
      "end": 564.52,
      "text": "escriba ahí en tu palabra"
    },
    {
      "start": 564.52,
      "end": 566.52,
      "text": "Señor inspirada, claro que"
    },
    {
      "start": 566.52,
      "end": 568.52,
      "text": "es por ti. Queremos"
    },
    {
      "start": 568.52,
      "end": 570.52,
      "text": "hoy aprender Señor"
    },
    {
      "start": 570.52,
      "end": 572.52,
      "text": "porque de esa manera Padre bendito"
    },
    {
      "start": 572.52,
      "end": 574.52,
      "text": "seguiremos firmes,"
    },
    {
      "start": 574.52,
      "end": 576.52,
      "text": "seguiremos Señor Dios"
    },
    {
      "start": 576.52,
      "end": 578.52,
      "text": "parados sobre una"
    },
    {
      "start": 578.52,
      "end": 580.52,
      "text": "doctrina, una enseñanza Señor,"
    },
    {
      "start": 580.52,
      "end": 582.52,
      "text": "un creer que tu"
    },
    {
      "start": 582.52,
      "end": 584.52,
      "text": "Señor has establecido."
    },
    {
      "start": 584.52,
      "end": 586.52,
      "text": "Gracias por usar la vida de nuestro Pastor."
    },
    {
      "start": 586.52,
      "end": 588.52,
      "text": "Estamos con ese deseo"
    },
    {
      "start": 588.52,
      "end": 590.52,
      "text": "de aprender el día"
    },
    {
      "start": 590.52,
      "end": 592.52,
      "text": "de hoy algo más Señor."
    },
    {
      "start": 592.52,
      "end": 594.52,
      "text": "Gracias Padre, con amor"
    },
    {
      "start": 594.52,
      "end": 596.52,
      "text": "recibimos de ti"
    },
    {
      "start": 596.52,
      "end": 598.52,
      "text": "esta enseñanza y también este día"
    },
    {
      "start": 598.52,
      "end": 600.52,
      "text": "oramos Señor"
    },
    {
      "start": 600.52,
      "end": 602.52,
      "text": "creemos que recibimos tu bendición"
    },
    {
      "start": 602.52,
      "end": 604.52,
      "text": "Ay Padre bueno"
    },
    {
      "start": 604.52,
      "end": 606.52,
      "text": "queremos alabarte"
    },
    {
      "start": 606.52,
      "end": 608.52,
      "text": "queremos decirte que estamos alegres"
    },
    {
      "start": 608.52,
      "end": 610.52,
      "text": "agradecidos"
    },
    {
      "start": 610.52,
      "end": 612.52,
      "text": "que hay gozo"
    },
    {
      "start": 612.52,
      "end": 614.52,
      "text": "mucho gozo en tu pueblo"
    },
    {
      "start": 614.52,
      "end": 616.52,
      "text": "Padre y que si algún"
    },
    {
      "start": 616.52,
      "end": 618.52,
      "text": "problema, alguna situación"
    },
    {
      "start": 618.52,
      "end": 620.52,
      "text": "difícil alguien está pasando"
    },
    {
      "start": 620.52,
      "end": 622.52,
      "text": "en el nombre de"
    },
    {
      "start": 622.52,
      "end": 624.52,
      "text": "Jesús"
    },
    {
      "start": 624.52,
      "end": 626.52,
      "text": "desaparece y en el nombre de"
    },
    {
      "start": 626.52,
      "end": 628.52,
      "text": "Jesús viene toda clase"
    },
    {
      "start": 628.52,
      "end": 630.52,
      "text": "de bendiciones y solucion"
    },
    {
      "start": 630.52,
      "end": 632.52,
      "text": "para cualquier problema Señor"
    },
    {
      "start": 632.52,
      "end": 634.52,
      "text": "que alguien este atravesando"
    },
    {
      "start": 634.52,
      "end": 636.52,
      "text": "tu eres el Dios"
    },
    {
      "start": 636.52,
      "end": 638.52,
      "text": "el que todo lo puede"
    },
    {
      "start": 638.52,
      "end": 640.52,
      "text": "y a ti Señor"
    },
    {
      "start": 640.52,
      "end": 642.52,
      "text": "te alabamos con todo nuestro"
    },
    {
      "start": 642.52,
      "end": 644.52,
      "text": "corazón, sea nuestra alabanza"
    },
    {
      "start": 644.52,
      "end": 646.52,
      "text": "para ti nos unimos Señor"
    },
    {
      "start": 646.52,
      "end": 648.52,
      "text": "a todo ese pueblo que también"
    },
    {
      "start": 648.52,
      "end": 650.52,
      "text": "en este momento te esta"
    },
    {
      "start": 650.52,
      "end": 652.52,
      "text": "alabando, gracias Padre"
    },
    {
      "start": 652.52,
      "end": 654.52,
      "text": "esta alabanza"
    },
    {
      "start": 654.52,
      "end": 656.52,
      "text": "y vamos a alabar al Señor"
    },
    {
      "start": 656.52,
      "end": 658.52,
      "text": "vamos a glorificar"
    },
    {
      "start": 658.52,
      "end": 660.52,
      "text": "a nuestro Dios"
    },
    {
      "start": 660.52,
      "end": 662.52,
      "text": "es hora de adorar"
    },
    {
      "start": 662.52,
      "end": 4374.52,
      "text": "a"
    }
  ],
  "title": "Formación de líderes en la iglesia"
}